#:kivy 2.3.0

<BattleWindow>:
    orientation: "vertical"
    padding: 8
    spacing: 8

    # 上：背景＋敵＋味方画像
    FloatLayout:
        id: battle_stage
        size_hint_y: 0.70

        canvas.before:
            Rectangle:
                source: "assets/images/battle_image.png"
                pos: self.pos
                size: self.size

        # 敵画像
        Image:
            source: root.enemy_image
            size_hint: 0.32, 0.32
            pos_hint: {"center_x": 0.30, "center_y": 0.52}
            allow_stretch: True
            keep_ratio: True

        # 敵名
        Label:
            text: root.enemy_name
            font_name: "GenShin"
            font_size: "24sp"
            color: 1, 1, 1, 1
            size_hint: 0.28, 0.10
            pos_hint: {"center_x": 0.30, "center_y": 0.24}
            halign: "center"
            valign: "middle"
            text_size: self.size

        # 勇者画像（敵と同サイズ）
        Image:
            id: hero_image
            source: "assets/images/yuusya_game.png"
            size_hint: 0.32, 0.32
            pos_hint: {"center_x": 0.78, "center_y": 0.52}
            allow_stretch: True
            keep_ratio: True

        # 勇者名
        Label:
            text: root.player_name
            font_name: "GenShin"
            font_size: "24sp"
            color: 1, 1, 1, 1
            size_hint: 0.28, 0.10
            pos_hint: {"center_x": 0.78, "center_y": 0.24}
            halign: "center"
            valign: "middle"
            text_size: self.size

    # 下：コマンド＋メッセージ＋HP枠
    BoxLayout:
        orientation: "horizontal"
        size_hint_y: 0.30
        spacing: 8

        # 左：コマンド
        BoxLayout:
            orientation: "vertical"
            size_hint_x: 0.28
            padding: 10

            canvas.before:
                Color:
                    rgba: 0.10, 0.08, 0.35, 0.95
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: 1, 1, 1, 1
                Line:
                    rectangle: self.x, self.y, self.width, self.height
                    width: 1.2

            Label:
                text: root.command_text
                font_name: "GenShin"
                font_size: "22sp"
                color: 1, 1, 1, 1
                halign: "left"
                valign: "top"
                text_size: self.size

        # 中央：メッセージ
        BoxLayout:
            orientation: "vertical"
            size_hint_x: 0.44
            padding: 10

            canvas.before:
                Color:
                    rgba: 0.10, 0.08, 0.35, 0.95
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: 1, 1, 1, 1
                Line:
                    rectangle: self.x, self.y, self.width, self.height
                    width: 1.2

            Label:
                text: root.message
                font_name: "GenShin"
                font_size: "22sp"
                color: 1, 1, 1, 1
                halign: "left"
                valign: "top"
                text_size: self.width - 16, self.height - 16

        # 右：HP枠
        BoxLayout:
            orientation: "vertical"
            size_hint_x: 0.28
            padding: 10
            spacing: 4

            canvas.before:
                Color:
                    rgba: 0.10, 0.08, 0.35, 0.95
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: 1, 1, 1, 1
                Line:
                    rectangle: self.x, self.y, self.width, self.height
                    width: 1.2

            Label:
                text: root.player_name
                font_name: "GenShin"
                font_size: "20sp"
                color: 1, 1, 1, 1
                halign: "left"
                valign: "middle"
                text_size: self.size

            Label:
                text: root.player_hp
                font_name: "GenShin"
                font_size: "18sp"
                color: 1, 1, 1, 1
                halign: "left"
                valign: "middle"
                text_size: self.size